@model PAS.ViewModels.ProjectDetailsViewModel

@{
    ViewData["Title"] = "Details";
}

<div class="d-flex align-items-center justify-content-between mb-3">
    <div>
        <h1 class="h3 mb-0">Proposal Details</h1>
        <div class="text-muted">Review what you submitted.</div>
    </div>
    <span class="badge text-bg-secondary">@Model.Project.Status</span>
</div>

<div class="card">
    <div class="card-body">
        <dl class="row mb-0">
            <dt class="col-sm-3">Title</dt>
            <dd class="col-sm-9">@Model.Project.Title</dd>

            <dt class="col-sm-3">Description</dt>
            <dd class="col-sm-9">@Model.Project.Description</dd>

            <dt class="col-sm-3">Tech Stack</dt>
            <dd class="col-sm-9">@Model.Project.TechStack</dd>

            <dt class="col-sm-3">Research Area</dt>
            <dd class="col-sm-9">@Model.Project.ResearchArea</dd>

            @if (string.Equals(Model.Project.Status, "Matched", StringComparison.OrdinalIgnoreCase))
            {
                <dt class="col-sm-3">Supervisor Contact</dt>
                <dd class="col-sm-9">@(Model.SupervisorEmail ?? "(not available)")</dd>
            }
        </dl>
    </div>
    <div class="card-footer d-flex gap-2">
        <a asp-action="Edit" asp-route-id="@Model.Project.Id" class="btn btn-outline-success">Edit</a>
        <a asp-action="Index" class="btn btn-outline-secondary">Back</a>
    </div>
</div>
