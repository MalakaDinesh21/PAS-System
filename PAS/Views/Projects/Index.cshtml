@model IEnumerable<PAS.Models.Project>
@{
    ViewData["Title"] = "My Projects";
}

<div class="d-flex align-items-center justify-content-between mb-3">
    <div>
        <h1 class="h3 mb-0">My Projects</h1>
        <div class="text-muted">Create proposals and track their status.</div>
    </div>
    <a asp-action="Create" class="btn btn-success">Create Proposal</a>
</div>

@if (!Model.Any())
{
    <div class="alert alert-secondary" role="alert">
        You haven’t submitted any proposals yet.
    </div>
}
else
{
    <div class="table-responsive">
        <table class="table table-striped align-middle">
            <thead>
                <tr>
                    <th>Title</th>
                    <th>Research Area</th>
                    <th>Status</th>
                    <th class="text-end">Actions</th>
                </tr>
            </thead>
            <tbody>
            @foreach (var item in Model)
            {
                <tr>
                    <td class="fw-semibold">@item.Title</td>
                    <td>@item.ResearchArea</td>
                    <td><span class="badge text-bg-secondary">@item.Status</span></td>
                    <td class="text-end">
                        <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-sm btn-outline-secondary">Details</a>
                        <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-outline-success">Edit</a>
                        <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-sm btn-outline-danger">Withdraw</a>
                    </td>
                </tr>
            }
            </tbody>
        </table>
    </div>
}
